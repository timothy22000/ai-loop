{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "The AI Loop dataset",
  "type": "object",
  "required": ["meta", "tape", "nodes", "edges", "companies"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["lastUpdated", "lastUpdatedLabel"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "tagline": { "type": "string" },
        "note": { "type": "string" },
        "sourcesNote": { "type": "string" },
        "lastUpdated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "lastUpdatedLabel": { "type": "string" },
        "pricesAsOf": { "type": "string" }
      }
    },
    "tape": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "string" },
          "teal": { "type": "boolean" }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "x", "y"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "big": { "type": "boolean" },
          "ext": { "type": "boolean" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "kind", "group", "amt", "status"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "kind": { "type": "string" },
          "group": { "enum": ["invest", "spend", "backstop"] },
          "amt": { "type": "string" },
          "status": { "enum": ["confirmed", "reported", "loi", "stalled"] },
          "source": { "type": "string", "format": "uri" },
          "verified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    },
    "companies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["company", "ticker", "price", "mktcap", "note", "cat"],
        "additionalProperties": false,
        "properties": {
          "company": { "type": "string" },
          "ticker": { "type": "string" },
          "cat": { "type": "string" },
          "price": { "type": "string" },
          "mktcap": { "type": "string" },
          "note": { "type": "string" },
          "source": { "type": "string", "format": "uri" }
        }
      }
    },
    "loops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "nodes", "note"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "note": { "type": "string" },
          "nodes": { "type": "array", "minItems": 2, "items": { "type": "string" } }
        }
      }
    },
    "supply": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "kind"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "kind": { "type": "string" }
        }
      }
    }
  }
}
