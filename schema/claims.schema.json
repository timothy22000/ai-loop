{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Loop claim registry",
  "type": "object",
  "required": ["meta", "sources", "claims"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "lastUpdated", "lastUpdatedLabel", "purpose", "statusKey"],
      "additionalProperties": true,
      "properties": {
        "title": {"type": "string"},
        "lastUpdated": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "lastUpdatedLabel": {"type": "string"},
        "purpose": {"type": "string"},
        "statusKey": {"type": "object"}
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "publisher", "title", "url", "type"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "publisher": {"type": "string"},
          "title": {"type": "string"},
          "url": {"type": "string", "format": "uri"},
          "published": {"type": ["string", "null"]},
          "type": {"enum": ["primary", "major-outlet", "specialist-outlet", "policy-research", "research-summary", "secondary", "vendor-blog", "other"]}
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "section", "label", "displayText", "normalizedValue", "status", "confidence", "sourceIds", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "section": {"enum": ["tape", "debate", "materials", "concentration", "lookthrough", "deal_context", "correction_watchlist", "methodology"]},
          "label": {"type": "string"},
          "displayText": {"type": "string"},
          "normalizedValue": {"type": "object"},
          "status": {"enum": ["verified", "reported", "estimate", "contested", "uncertain", "needs_update"]},
          "confidence": {"enum": ["high", "medium", "low"]},
          "sourceIds": {"type": "array", "items": {"type": "string"}},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
